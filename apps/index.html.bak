<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ecomarket | El Marketplace de Confianza Ética</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700&display=swap');
        
        :root {
            --primary: #1A3C34;
            --soft-green: #E9F0E8;
            --accent: #D4A373;
            --white-dirty: #FDFCF9;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--white-dirty);
            color: #1a1a1a;
        }

        .product-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        .category-scroll::-webkit-scrollbar {
            display: none;
        }

        .eco-gradient {
            background: linear-gradient(135deg, #1A3C34 0%, #2D5A27 100%);
        }

        .badge-verified {
            background: rgba(45, 90, 39, 0.1);
            color: #2D5A27;
        }
    </style>
</head>
<body>

    <!-- Barra de Notificaciones -->
    <div class="bg-[#1A3C34] text-white text-[11px] py-2 px-6 flex justify-between items-center font-bold tracking-widest uppercase">
        <span><i class="fas fa-shipping-fast mr-2"></i> Envíos Carbono Neutral en todo el país</span>
        <span class="hidden md:block">Garantía Ecomarket: 100% Auditado</span>
    </div>

    <!-- Navegación -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-2 cursor-pointer">
                    <div class="w-9 h-9 bg-[#1A3C34] rounded-lg flex items-center justify-center text-white">
                        <i class="fas fa-leaf text-lg"></i>
                    </div>
                    <span class="text-xl font-bold tracking-tighter text-[#1A3C34]">ecomarket</span>
                </div>
                
                <div class="hidden lg:flex gap-6 text-sm font-semibold text-gray-500">
                    <a href="#" class="hover:text-[#1A3C34] transition">Cuidado Personal</a>
                    <a href="#" class="hover:text-[#1A3C34] transition">Alimentación</a>
                    <a href="#" class="hover:text-[#1A3C34] transition">Hogar Eco</a>
                    <a href="#" class="hover:text-[#1A3C34] transition text-orange-600">Nuevas Auditorías</a>
                </div>
            </div>

            <div class="flex items-center gap-5">
                <div class="hidden md:flex bg-gray-100 rounded-full px-4 py-2 items-center gap-2">
                    <i class="fas fa-search text-gray-400 text-sm"></i>
                    <input type="text" placeholder="Buscar productos auditados..." class="bg-transparent border-none focus:outline-none text-sm w-48">
                </div>
                <div class="flex gap-4 text-gray-600">
                    <button class="relative">
                        <i class="fas fa-shopping-basket text-xl"></i>
                        <span class="absolute -top-2 -right-2 bg-[#1A3C34] text-white text-[10px] w-4 h-4 rounded-full flex items-center justify-center">2</span>
                    </button>
                    <button class="hidden sm:block"><i class="far fa-user text-xl"></i></button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Categorías Rápidas -->
    <div class="max-w-7xl mx-auto px-6 py-8">
        <div class="flex gap-4 overflow-x-auto category-scroll pb-2">
            <button class="flex-none bg-[#1A3C34] text-white px-6 py-3 rounded-2xl font-bold text-sm shadow-lg">Todos</button>
            <button class="flex-none bg-white border border-gray-100 px-6 py-3 rounded-2xl font-semibold text-sm hover:border-green-600 transition">Vegano Estricto</button>
            <button class="flex-none bg-white border border-gray-100 px-6 py-3 rounded-2xl font-semibold text-sm hover:border-green-600 transition text-green-700"><i class="fas fa-recycle mr-2"></i>Zero Waste</button>
            <button class="flex-none bg-white border border-gray-100 px-6 py-3 rounded-2xl font-semibold text-sm hover:border-green-600 transition">Belleza Limpia</button>
            <button class="flex-none bg-white border border-gray-100 px-6 py-3 rounded-2xl font-semibold text-sm hover:border-green-600 transition">Comercio Justo</button>
            <button class="flex-none bg-white border border-gray-100 px-6 py-3 rounded-2xl font-semibold text-sm hover:border-green-600 transition">Biodegradable</button>
        </div>
    </div>

    <!-- Hero Marketplace -->
    <section class="max-w-7xl mx-auto px-6 mb-16">
        <div class="eco-gradient rounded-[2.5rem] p-12 text-white flex flex-col md:flex-row items-center justify-between relative overflow-hidden">
            <div class="relative z-10 max-w-lg">
                <span class="text-green-300 font-bold uppercase text-xs tracking-widest">Edición Abril 2024</span>
                <h2 class="text-4xl md:text-5xl font-extrabold mt-4 mb-6 leading-tight">Tu compra tiene un <span class="text-green-400 italic">propósito real.</span></h2>
                <p class="text-green-100/80 mb-8 text-lg">Descubre productos validados ingrediente por ingrediente. Sin greenwashing, solo la verdad técnica.</p>
                <div class="flex gap-4">
                    <button class="bg-white text-[#1A3C34] px-8 py-3 rounded-xl font-bold shadow-xl hover:bg-green-50 transition">Comprar Ahora</button>
                    <button class="bg-transparent border border-white/30 px-8 py-3 rounded-xl font-bold hover:bg-white/10 transition">Nuestro Método</button>
                </div>
            </div>
            <div class="hidden md:block relative z-10 w-1/3">
                <div class="bg-white/10 backdrop-blur-xl rounded-3xl p-6 border border-white/20">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-10 h-10 bg-green-400 rounded-full flex items-center justify-center text-black">
                            <i class="fas fa-check"></i>
                        </div>
                        <p class="text-xs font-bold uppercase tracking-widest">Certificación Ecomarket</p>
                    </div>
                    <p class="text-sm italic">"Auditamos más de 12,000 ingredientes químicos para que tú no tengas que hacerlo."</p>
                </div>
            </div>
            <!-- Decoración -->
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-green-400 rounded-full blur-[120px] opacity-20"></div>
        </div>
    </section>

    <!-- Grilla de Productos -->
    <main class="max-w-7xl mx-auto px-6 mb-24">
        <div class="flex justify-between items-end mb-10">
            <div>
                <h3 class="text-3xl font-bold text-gray-900">Selección Curada</h3>
                <p class="text-gray-500 mt-2 font-medium">Productos que superaron el 9.0 en nuestro Eco-Score</p>
            </div>
            <a href="#" class="text-[#1A3C34] font-bold border-b-2 border-[#1A3C34] pb-1 hover:text-green-700 transition">Ver todos los productos</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            
            <!-- Producto 1 -->
            <div class="product-card bg-white rounded-[2rem] p-5 border border-gray-100 flex flex-col group cursor-pointer">
                <div class="relative bg-[#F3F5F2] rounded-2xl aspect-square flex items-center justify-center overflow-hidden mb-5">
                    <i class="fas fa-bottle-water text-6xl text-gray-300"></i>
                    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                        <span class="text-sm font-bold text-[#1A3C34]">9.8</span>
                        <i class="fas fa-star text-[10px] text-yellow-500"></i>
                    </div>
                    <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform bg-[#1A3C34]/80 backdrop-blur-sm">
                        <button class="w-full text-white text-xs font-bold uppercase tracking-widest">Vista Rápida</button>
                    </div>
                </div>
                <div class="flex-grow">
                    <p class="text-[10px] font-bold text-green-700 uppercase tracking-widest mb-1">Cuidado del Cabello</p>
                    <h4 class="font-bold text-gray-900 mb-2">Shampoo Sólido de Verbena</h4>
                    <div class="flex gap-2 mb-4">
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Plastic Free</span>
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Vegan</span>
                    </div>
                </div>
                <div class="flex justify-between items-center pt-4 border-t border-gray-50">
                    <span class="text-xl font-extrabold text-gray-900">$14.50</span>
                    <button class="w-10 h-10 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-[#1A3C34] transition">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            <!-- Producto 2 -->
            <div class="product-card bg-white rounded-[2rem] p-5 border border-gray-100 flex flex-col group cursor-pointer">
                <div class="relative bg-[#F3F5F2] rounded-2xl aspect-square flex items-center justify-center overflow-hidden mb-5">
                    <i class="fas fa-bowl-food text-6xl text-gray-300"></i>
                    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                        <span class="text-sm font-bold text-[#1A3C34]">9.5</span>
                        <i class="fas fa-star text-[10px] text-yellow-500"></i>
                    </div>
                </div>
                <div class="flex-grow">
                    <p class="text-[10px] font-bold text-green-700 uppercase tracking-widest mb-1">Alimentación</p>
                    <h4 class="font-bold text-gray-900 mb-2">Proteína de Arveja Orgánica</h4>
                    <div class="flex gap-2 mb-4">
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Gluten Free</span>
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Keto</span>
                    </div>
                </div>
                <div class="flex justify-between items-center pt-4 border-t border-gray-50">
                    <span class="text-xl font-extrabold text-gray-900">$32.00</span>
                    <button class="w-10 h-10 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-[#1A3C34] transition">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            <!-- Producto 3 -->
            <div class="product-card bg-white rounded-[2rem] p-5 border border-gray-100 flex flex-col group cursor-pointer">
                <div class="relative bg-[#F3F5F2] rounded-2xl aspect-square flex items-center justify-center overflow-hidden mb-5">
                    <i class="fas fa-soap text-6xl text-gray-300"></i>
                    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                        <span class="text-sm font-bold text-[#1A3C34]">9.2</span>
                        <i class="fas fa-star text-[10px] text-yellow-500"></i>
                    </div>
                </div>
                <div class="flex-grow">
                    <p class="text-[10px] font-bold text-green-700 uppercase tracking-widest mb-1">Limpieza Hogar</p>
                    <h4 class="font-bold text-gray-900 mb-2">Detergente Biodegradable</h4>
                    <div class="flex gap-2 mb-4">
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Ecolabel</span>
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Refill</span>
                    </div>
                </div>
                <div class="flex justify-between items-center pt-4 border-t border-gray-50">
                    <span class="text-xl font-extrabold text-gray-900">$18.90</span>
                    <button class="w-10 h-10 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-[#1A3C34] transition">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

            <!-- Producto 4 -->
            <div class="product-card bg-white rounded-[2rem] p-5 border border-gray-100 flex flex-col group cursor-pointer">
                <div class="relative bg-[#F3F5F2] rounded-2xl aspect-square flex items-center justify-center overflow-hidden mb-5">
                    <i class="fas fa-brush text-6xl text-gray-300"></i>
                    <div class="absolute top-3 right-3 bg-white/90 backdrop-blur px-3 py-1 rounded-full flex items-center gap-1 shadow-sm">
                        <span class="text-sm font-bold text-[#1A3C34]">9.9</span>
                        <i class="fas fa-star text-[10px] text-yellow-500"></i>
                    </div>
                </div>
                <div class="flex-grow">
                    <p class="text-[10px] font-bold text-green-700 uppercase tracking-widest mb-1">Higiene</p>
                    <h4 class="font-bold text-gray-900 mb-2">Cepillo Bambú Moso</h4>
                    <div class="flex gap-2 mb-4">
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">Compostable</span>
                        <span class="badge-verified text-[9px] font-bold px-2 py-0.5 rounded uppercase">BPA Free</span>
                    </div>
                </div>
                <div class="flex justify-between items-center pt-4 border-t border-gray-50">
                    <span class="text-xl font-extrabold text-gray-900">$5.50</span>
                    <button class="w-10 h-10 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-[#1A3C34] transition">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>

        </div>
    </main>

    <!-- Sección de Auditoría e IA (Diferenciador Técnico) -->
    <section class="max-w-7xl mx-auto px-6 mb-24">
        <div class="bg-white rounded-[3rem] p-8 md:p-16 border border-gray-100 flex flex-col lg:flex-row gap-16 items-center">
            <div class="lg:w-1/2">
                <h3 class="text-4xl font-bold mb-6 text-[#1A3C34]">Nuestra Auditoría Inteligente</h3>
                <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                    A diferencia de otros mercados, en Ecomarket cada producto pasa por un **Pipeline de Validación Estadística**. No solo miramos la etiqueta; auditamos la cadena de suministro completa.
                </p>
                <div class="space-y-6">
                    <div class="flex gap-5 items-start">
                        <div class="w-12 h-12 bg-green-50 rounded-2xl flex items-center justify-center text-green-700 flex-shrink-0">
                            <i class="fas fa-eye text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold text-gray-900">Análisis Visión IA</h5>
                            <p class="text-sm text-gray-500">Escaneo de etiquetas mediante Visión Artificial para detectar 12,000+ químicos nocivos.</p>
                        </div>
                    </div>
                    <div class="flex gap-5 items-start">
                        <div class="w-12 h-12 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-700 flex-shrink-0">
                            <i class="fas fa-shield-halved text-xl"></i>
                        </div>
                        <div>
                            <h5 class="font-bold text-gray-900">Verificación Inmutable</h5>
                            <p class="text-sm text-gray-500">Registro de certificados de origen en una base de datos de auditoría inmutable.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="lg:w-1/2 bg-[#F9FBF8] rounded-[2rem] p-8 border border-green-100 relative">
                <div class="absolute -top-4 -left-4 bg-green-600 text-white px-6 py-2 rounded-xl text-xs font-bold uppercase tracking-widest shadow-lg">
                    Simulación en Vivo
                </div>
                <div class="space-y-4 font-mono text-[11px] text-gray-600">
                    <div class="flex justify-between border-b border-gray-100 pb-2">
                        <span>> Analizando ingredientes...</span>
                        <span class="text-green-600">[OK]</span>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 pb-2">
                        <span>> Verificando Certificación ISO 14001...</span>
                        <span class="text-green-600">[VALID]</span>
                    </div>
                    <div class="flex justify-between border-b border-gray-100 pb-2">
                        <span>> Calculando Huella de Carbono Logística...</span>
                        <span class="text-blue-600">0.04kg CO2</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="font-bold text-gray-800">> GENERANDO ECO-SCORE FINAL:</span>
                        <span class="text-xl font-bold text-green-700">9.7 / 10</span>
                    </div>
                </div>
                <div class="mt-8 pt-8 border-t border-gray-200">
                    <div class="bg-white p-4 rounded-xl flex items-center gap-4 shadow-sm">
                        <div class="w-12 h-12 rounded-full bg-gray-100 overflow-hidden">
                            <i class="fas fa-user-tie text-3xl text-gray-300 mt-2 ml-2"></i>
                        </div>
                        <div>
                            <p class="text-[10px] font-bold text-gray-400 uppercase">Firma del Auditor</p>
                            <p class="text-sm font-bold italic">Auditoría Aprobada por Dr. R. Silva</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer / Conversión de Vendedores -->
    <footer class="bg-gray-50 border-t border-gray-200 pt-20 pb-10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
                <div class="col-span-1 lg:col-span-1">
                    <div class="flex items-center gap-2 mb-6">
                        <div class="w-8 h-8 bg-[#1A3C34] rounded-lg flex items-center justify-center text-white">
                            <i class="fas fa-leaf"></i>
                        </div>
                        <span class="text-xl font-bold tracking-tighter text-[#1A3C34]">ecomarket</span>
                    </div>
                    <p class="text-sm text-gray-500 mb-6 leading-relaxed">
                        Redefiniendo el e-commerce a través de la ciencia y la transparencia. Únete a la revolución del consumo consciente.
                    </p>
                    <div class="flex gap-4">
                        <a href="#" class="w-10 h-10 bg-white border border-gray-200 rounded-full flex items-center justify-center text-gray-400 hover:text-green-600 transition"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="w-10 h-10 bg-white border border-gray-200 rounded-full flex items-center justify-center text-gray-400 hover:text-green-600 transition"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div>
                    <h6 class="font-bold text-gray-900 mb-6">Explorar</h6>
                    <ul class="text-sm text-gray-500 space-y-4">
                        <li><a href="#" class="hover:text-green-700 transition">Todos los Productos</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Categorías Veganas</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Marcas Auditadas</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Ofertas Eco</a></li>
                    </ul>
                </div>
                <div>
                    <h6 class="font-bold text-gray-900 mb-6">Compañía</h6>
                    <ul class="text-sm text-gray-500 space-y-4">
                        <li><a href="#" class="hover:text-green-700 transition">Cómo Auditamos</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Transparencia</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Misión Social</a></li>
                        <li><a href="#" class="hover:text-green-700 transition">Contacto</a></li>
                    </ul>
                </div>
                <div class="bg-[#1A3C34] rounded-[2rem] p-8 text-white">
                    <h6 class="font-bold mb-4">¿Eres productor?</h6>
                    <p class="text-xs text-green-100/70 mb-6">Sube tus certificados y empieza a vender con nuestro sello de confianza.</p>
                    <button class="w-full bg-green-500 text-white py-3 rounded-xl font-bold text-sm hover:bg-green-600 transition">Vender en Ecomarket</button>
                </div>
            </div>
            <div class="border-t border-gray-200 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
                <p>© 2024 Ecomarket Software Inc. Todos los derechos reservados.</p>
                <div class="flex gap-8">
                    <a href="#">Privacidad</a>
                    <a href="#">Términos de Auditoría</a>
                    <a href="#">Sostenibilidad Reporte</a>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>